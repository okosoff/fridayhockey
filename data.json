<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Payment Admin - Phan's Hockey</title>
<style>
:root{--bg:#1a1a1a;--card:#2d2d2d;--text:#fff;--accent:#ff6b00;--success:#4CAF50;--danger:#ff4444;--warning:#ff9800;}
*{box-sizing:border-box;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif}
body{background:var(--bg);color:var(--text);margin:0;padding:20px;min-height:100vh;display:flex;justify-content:center;align-items:flex-start}
.container{width:100%;max-width:960px;background:var(--card);border:1px solid #444;border-radius:15px;padding:26px;box-shadow:0 10px 30px rgba(0,0,0,.5)}
h1{color:var(--accent);text-align:center;text-transform:uppercase;letter-spacing:1.5px;margin:0 0 8px}
.sub{text-align:center;color:#bbb;margin-bottom:18px}.login-box,.registered-players-box,.pending-box,.summary-box{border-radius:12px;padding:18px;margin:16px 0}.login-box{background:linear-gradient(135deg,#2a1a3a,#3d2d4d);border:2px solid var(--accent)}.pending-box{background:linear-gradient(135deg,#3a2a1a,#4d3d2d);border:2px solid var(--warning);text-align:center;color:#ffd18a}.registered-players-box{background:linear-gradient(135deg,#2a1a1a,#332222);border:2px solid var(--accent)}.summary-box{background:linear-gradient(135deg,#1a3a1a,#2d4d2d);border:2px solid var(--success);display:grid;grid-template-columns:repeat(3,1fr);gap:10px;text-align:center}.stat{background:rgba(0,0,0,.2);border-radius:10px;padding:12px}.stat strong{display:block;font-size:1.45rem;color:var(--success)}.stat span{font-size:.8rem;color:#bbb}
input{width:100%;padding:12px;margin:8px 0;background:#3d3d3d;border:1px solid #555;color:#fff;border-radius:8px;font-size:1rem}button{background:var(--accent);color:#fff;border:0;border-radius:8px;padding:10px 14px;font-weight:800;cursor:pointer}button:hover{background:#ff8533}.logout{background:#666;float:right}.refresh{background:#4a90e2}.error{display:none;background:var(--danger);padding:10px;border-radius:8px;text-align:center;margin-top:10px}.top-actions{display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;margin-bottom:10px}
table{width:100%;border-collapse:collapse;margin-top:8px}th,td{border-bottom:1px solid #444;padding:7px 6px;text-align:center;vertical-align:middle}th{color:var(--accent)}td:first-child{text-align:left}.name-main{font-weight:800}.phone,.time{display:block;color:#aaa;font-size:.76rem;margin-top:2px}.rating-pill{display:inline-block;background:#4a4a4a;border:1px solid #777;border-radius:8px;padding:4px 9px;font-weight:800}.pay-pill{display:inline-flex;align-items:center;justify-content:center;min-width:78px;min-height:30px;border-radius:9px;font-weight:900}.paid{background:#2e7d32}.owes{background:#c62828}.pia{background:#1565c0}.action-stack{display:flex;gap:6px;justify-content:center;flex-wrap:wrap}.paid-btn{background:#2e7d32}.owes-btn{background:#b71c1c}.amount-btn{background:#1565c0}.goalie-note{color:#ffb366;font-size:.78rem;font-weight:800}.hidden{display:none!important}
@media(max-width:700px){body{padding:10px}.container{padding:16px}.summary-box{grid-template-columns:repeat(3,minmax(0,1fr));gap:6px}.stat{padding:9px}.stat strong{font-size:1.05rem}th,td{font-size:.78rem;padding:6px 3px}.phone{font-size:.66rem}.action-stack button{font-size:.7rem;padding:7px 8px}.hide-mobile{display:none}}
</style>
</head>
<body>
<div class="container">
<button class="logout hidden" id="logoutBtn" onclick="logout()">Logout</button>
<h1>Payment Admin</h1>
<div class="sub">For Kyle / Brad — collect money after roster release only.</div>

<div class="login-box" id="loginBox">
  <h3>Enter Collector Password</h3>
  <input type="password" id="passwordInput" placeholder="Password" autocomplete="current-password">
  <button onclick="login()">Login</button>
  <div class="error" id="loginError"></div>
</div>

<div id="collectorPanel" class="hidden">
  <div class="top-actions"><button class="refresh" onclick="loadData()">Refresh</button></div>
  <div id="gameInfo" class="sub"></div>
  <div class="pending-box hidden" id="pendingBox"><h3>⏳ Roster Not Released Yet</h3><div>This page will show registered players only after the roster is released.</div></div>
  <div class="summary-box hidden" id="summaryBox">
    <div class="stat"><strong id="totalCollected">$0</strong><span>Total Collected</span></div>
    <div class="stat"><strong id="paidCount">0</strong><span>Paid</span></div>
    <div class="stat"><strong id="unpaidCount">0</strong><span>Owes</span></div>
  </div>
  <div class="registered-players-box hidden" id="playersBox">
    <h3 id="playersTitle">🏒 Registered Players</h3>
    <table>
      <thead><tr><th>Name</th><th>Rating</th><th>Paid ($)</th><th>Action</th></tr></thead>
      <tbody id="playerList"></tbody>
    </table>
  </div>
</div>
</div>
<script>
const API_URL = window.location.origin;
const TOKEN_KEY = 'phansCollectorSessionToken';
let sessionToken = localStorage.getItem(TOKEN_KEY) || '';

function headers(){return {'Content-Type':'application/json','Authorization':'Bearer '+sessionToken,'X-Admin-Auth':sessionToken};}
function fmtTime(v){try{return new Date(v).toLocaleString('en-US',{month:'numeric',day:'numeric',hour:'numeric',minute:'2-digit',hour12:true});}catch(e){return '';}}
function escapeHtml(s){return String(s??'').replace(/[&<>'"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));}

async function login(){
  const password = document.getElementById('passwordInput').value.trim();
  const err = document.getElementById('loginError'); err.style.display='none';
  try{
    const res = await fetch(`${API_URL}/api/collector/login`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password,rememberMe:true})});
    const data = await res.json().catch(()=>({}));
    if(!res.ok) throw new Error(data.error || 'Invalid password');
    sessionToken = data.sessionToken; localStorage.setItem(TOKEN_KEY, sessionToken);
    document.getElementById('loginBox').classList.add('hidden');
    document.getElementById('collectorPanel').classList.remove('hidden');
    document.getElementById('logoutBtn').classList.remove('hidden');
    await loadData();
  }catch(e){err.textContent=e.message || 'Login failed'; err.style.display='block';}
}
function logout(){localStorage.removeItem(TOKEN_KEY); sessionToken=''; location.reload();}

async function loadData(){
  if(!sessionToken) return;
  const res = await fetch(`${API_URL}/api/collector/players`,{method:'POST',headers:headers(),body:JSON.stringify({sessionToken})});
  if(res.status===401){logout(); return;}
  const data = await res.json().catch(()=>({}));
  if(!res.ok){alert(data.error || 'Could not load data'); return;}
  document.getElementById('gameInfo').innerHTML = `${escapeHtml(data.date || '')} ${escapeHtml(data.time || '')}<br><strong>${escapeHtml(data.location || '')}</strong>`;
  if(!data.rosterReleased){
    document.getElementById('pendingBox').classList.remove('hidden');
    document.getElementById('summaryBox').classList.add('hidden');
    document.getElementById('playersBox').classList.add('hidden');
    return;
  }
  document.getElementById('pendingBox').classList.add('hidden');
  document.getElementById('summaryBox').classList.remove('hidden');
  document.getElementById('playersBox').classList.remove('hidden');
  document.getElementById('totalCollected').textContent = '$' + Number(data.totalPaid || 0).toFixed(2);
  document.getElementById('paidCount').textContent = data.paidCount || 0;
  document.getElementById('unpaidCount').textContent = data.unpaidCount || 0;
  document.getElementById('playersTitle').textContent = `🏒 Registered Players (${data.playerCount || 0} Players, ${data.goalieCount || 0} Goalies)`;
  renderPlayers(data.players || []);
}

function paymentState(p){
  const st = String(p.paymentStatus || '').toLowerCase();
  if(st === 'pia') return {label:'PIA', cls:'pia'};
  const amt = Number(p.paidAmount);
  if(Number.isFinite(amt) && amt > 0) return {label:'$'+amt.toFixed(0), cls:'paid'};
  return {label:'OWES', cls:'owes'};
}
function renderPlayers(players){
  const tbody = document.getElementById('playerList'); tbody.innerHTML='';
  const sorted = [...players].sort((a,b)=>{
    const ap = String(a.firstName||'').toLowerCase()==='phan', bp = String(b.firstName||'').toLowerCase()==='phan';
    if(ap && !bp) return -1; if(!ap && bp) return 1;
    if(a.isGoalie && !b.isGoalie) return -1; if(!a.isGoalie && b.isGoalie) return 1;
    return String(a.lastName||'').localeCompare(String(b.lastName||''));
  });
  for(const p of sorted){
    const isPhan = String(p.firstName||'').toLowerCase()==='phan' && String(p.lastName||'').toLowerCase()==='ly';
    const state = paymentState(p);
    const actions = (p.isGoalie || isPhan) ? '<span class="goalie-note">No collection</span>' : `<div class="action-stack"><button class="paid-btn" onclick="setPaid(${p.id},15)">$15 Paid</button><button class="amount-btn" onclick="customAmount(${p.id})">Other</button><button class="owes-btn" onclick="setPaid(${p.id},null)">Owes</button></div>`;
    const tr = document.createElement('tr');
    tr.innerHTML = `<td><span class="name-main">${escapeHtml(p.firstName)} ${escapeHtml(p.lastName)}${p.isGoalie?' <span class="goalie-note">GOALIE</span>':''}</span><span class="phone">${escapeHtml(p.phone||'')}</span>${p.registeredAt?`<span class="time">🔒 ${fmtTime(p.registeredAt)}</span>`:''}</td><td><span class="rating-pill">${Number(p.finalRating ?? p.rating ?? 5).toFixed(1)}</span></td><td><span class="pay-pill ${state.cls}">${state.label}</span></td><td>${actions}</td>`;
    tbody.appendChild(tr);
  }
}
async function setPaid(playerId, amount){
  if(amount === null && !confirm('Mark this player as owing?')) return;
  const res = await fetch(`${API_URL}/api/collector/update-paid-amount`,{method:'POST',headers:headers(),body:JSON.stringify({sessionToken,playerId,amount})});
  const data = await res.json().catch(()=>({}));
  if(!res.ok){alert(data.error || 'Payment update failed'); return;}
  await loadData();
}
async function customAmount(playerId){
  const raw = prompt('Enter amount collected:', '15');
  if(raw === null) return;
  const amount = Number(raw);
  if(!Number.isFinite(amount) || amount < 0){alert('Enter a valid amount.'); return;}
  await setPaid(playerId, amount);
}
if(sessionToken){document.getElementById('loginBox').classList.add('hidden');document.getElementById('collectorPanel').classList.remove('hidden');document.getElementById('logoutBtn').classList.remove('hidden');loadData();}
setInterval(()=>{if(sessionToken) loadData();},30000);
document.getElementById('passwordInput').addEventListener('keydown',e=>{if(e.key==='Enter')login();});
</script>
</body>
</html>
